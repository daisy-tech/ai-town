# LLM Configuration Example
# Copy this file to ../../.env.llm (project root) and fill in your values
# Do NOT commit real API keys

# Qwen / DashScope (OpenAI-compatible)
# Note: do not include trailing /v1 — the code appends /v1/chat/completions
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode
LLM_API_KEY=your-api-key-here
LLM_MODEL=qwen-plus
LLM_EMBEDDING_MODEL=text-embedding-v3

# OpenAI (uncomment to use)
# OPENAI_API_KEY=your-key-here
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Together.ai (uncomment to use)
# TOGETHER_API_KEY=your-key-here
# TOGETHER_CHAT_MODEL=meta-llama/Llama-3-8b-chat-hf
# TOGETHER_EMBEDDING_MODEL=togethercomputer/m2-bert-80M-8k-retrieval

# Ollama (uncomment to use)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3
# OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
