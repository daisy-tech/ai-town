# AI Town 环境配置
# 复制为 .env.local 或 .env.llm 并填写（切勿提交真实 Key）

# ============================================
# 自托管 Convex（Docker）
# ============================================
# CONVEX_SELF_HOSTED_URL="http://127.0.0.1:3210"
# CONVEX_SELF_HOSTED_ADMIN_KEY="convex-self-hosted|..."
# VITE_CONVEX_URL=http://127.0.0.1:3210

# ============================================
# Convex 云端（可选）
# ============================================
# VITE_CONVEX_URL=https://your-project.convex.cloud

# ============================================
# 本地实验模块（src/localBackend）
# ============================================
BACKEND_TYPE=local
LOCAL_DATA_DIR=./data

# ============================================
# LLM（通义千问 / OpenAI 兼容接口）
# URL 不要带末尾 /v1
# ============================================
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode
LLM_API_KEY=your-api-key-here
LLM_MODEL=qwen-plus
LLM_EMBEDDING_MODEL=text-embedding-v3

# ============================================
# 记忆系统
# ============================================
NUM_MEMORIES_TO_SEARCH=3
REFLECTION_THRESHOLD=500
